# Hinweis: Diese Datei enthält **nur Variablennamen** (keine echten Werte).
# Kopiere sie nach `.env.local` (lokal) oder setze Variablen im Hosting (z. B. Vercel).

# === Supabase (App) ===
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional (nur falls benötigt / Self-hosting)
SUPABASE_URL=

# Service Role (NUR serverseitig verwenden; niemals im Client!)
SUPABASE_SERVICE_ROLE_KEY=

# App URL(s)
NEXT_PUBLIC_SITE_URL=
# Optional legacy fallback (avoid in new setups)
NEXT_PUBLIC_APP_URL=

# === Contact Form ===
CONTACT_EMAIL_PHYSIOTHERAPY=
CONTACT_EMAIL_PHYSIOKONZEPT=
CONTACT_FALLBACK_EMAIL=
CONTACT_FROM_EMAIL=
CONTACT_MAIL_PROVIDER=
RESEND_API_KEY=
CONTACT_ALLOWED_ORIGINS=

# Test mode (optional)
CONTACT_TEST_MODE=
CONTACT_TEST_EMAIL=

# Cookie scan (optional)
COOKIE_SCAN_ALLOW_LOCALHOST=
